<BaseLayout
  title="旅行攻略——20篇深度游指南，走遍中国"
  description="候鸟旅途博客——收录云南丽江、四川九寨沟、湖南张家界、西藏拉萨等20个中国热门旅游目的地的详细攻略，景点指南、美食推荐、住宿交通全维度覆盖。"
  keywords={["旅行攻略","自由行指南","中国旅游","深度游","丽江","九寨沟","张家界","拉萨"]}
>
  <section class="page-header">
    <div class="container">
      <h1>📝 旅行攻略</h1>
      <p>20 篇深度攻略，覆盖中国最美目的地</p>
    </div>
  </section>

  <section class="blog-list">
    {posts.map((post) => (
      <article class="blog-card">
        <img class="blog-card__image" src={post.image} alt={post.imageAlt} loading="lazy" />
        <div class="blog-card__body">
          <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:0.75rem;">
            {post.tags.slice(0,4).map((tag) => <span class="tag">{tag}</span>)}
          </div>
          <h2><a href={`/blog/${post.slug}`}>{post.title}</a></h2>
          <p>{post.description}</p>
          <div class="blog-card__meta">
            📅 {new Date(post.date).toLocaleDateString("zh-CN",{year:"numeric",month:"long",day:"numeric"})} · ✍️ {post.author}
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
